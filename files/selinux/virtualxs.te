module virtualxs 1.4;

require {
    type fail2ban_t;
    type home_root_t;
    type httpd_sys_content_t;
    type httpd_log_t;
    type postfix_cleanup_t;
    type mysqld_etc_t;
    type httpd_t;
    type security_t;
    type etc_t;
    type httpd_config_t;
    type passwd_file_t;
    type shadow_t;
    type var_log_t;
    type logrotate_t;
    type fixed_disk_device_t;
    type user_home_dir_t;
    type user_home_t;
    type bin_t;
    type cert_t;
    type fs_t;
    type mail_spool_t;
    type httpd_unit_file_t;
    type adjtime_t;
    type cupsd_rw_etc_t;
    type etc_aliases_t;
    type exports_t;
    type initrc_exec_t;
    type kdump_etc_t;
    type rsync_etc_t;
    type syslog_conf_t;
    type system_cron_spool_t;
    class dir { add_name create getattr open read remove_name search setattr write };
    class file { append create entrypoint getattr ioctl link open read rename setattr unlink write };
    class security compute_av;
    class capability { audit_write fowner fsetid sys_admin sys_resource };
    class blk_file { getattr ioctl open read };
    class filesystem { quotaget quotamod };
    class netlink_audit_socket nlmsg_relay;
    class service { status };
}

# fail2ban: Traversal through /home/ to /home/httpd
allow fail2ban_t home_root_t:dir search;

# fail2ban: Read webroot and log paths under /home/httpd/
allow fail2ban_t httpd_sys_content_t:dir { getattr open read search };
allow fail2ban_t httpd_log_t:dir { getattr open read search };
allow fail2ban_t httpd_log_t:file { getattr ioctl open read };

# postfix_cleanup: Read MySQL config under /etc/my.cnf and /etc/my.cnf.d/
allow postfix_cleanup_t mysqld_etc_t:dir search;
allow postfix_cleanup_t mysqld_etc_t:file { getattr open read };

# httpd_t (PHP-FPM): VirtualX Serververwaltung via sudo
# sudo benoetigt compute_av auf security_t (SELinux-interner Check)
allow httpd_t security_t:security compute_av;

# sudo benoetigt audit_write-Capability (Audit-System) und fsetid (useradd Dateiberechtigungen)
# sowie netlink_audit_socket fuer Audit-Kommunikation
# fowner: Eigentuemer von Domain-Verzeichnissen setzen
# sys_admin: xfs_quota-Zugriff
# sys_resource: setrlimit(rlimit_core) durch sudo
allow httpd_t self:capability { audit_write fowner fsetid sys_admin sys_resource };
allow httpd_t self:netlink_audit_socket nlmsg_relay;

# useradd/chpasswd: Schreiben in /etc/passwd und /etc/shadow
allow httpd_t passwd_file_t:file { create rename setattr unlink write };
allow httpd_t shadow_t:file { create getattr open read rename setattr unlink write };

# VirtualHost-Konfiguration: Schreiben in /etc/httpd/
allow httpd_t httpd_config_t:dir { add_name write };
allow httpd_t httpd_config_t:file { append create setattr write };

# FPM-Pool + vsftpd-Config: Schreiben in /etc/ (etc_t-Verzeichnisse und Dateien)
# mkdir/openssl in /etc/letsencrypt/live/ benoetigt create/search/getattr
allow httpd_t etc_t:dir { add_name create getattr read remove_name search write };
allow httpd_t etc_t:file { create getattr link open read rename setattr unlink write };

# Log-Verzeichnis anlegen und befuellen in /var/log/
allow httpd_t var_log_t:dir { add_name create getattr search write };

# certbot/letsencrypt logs (var_log_t)
allow httpd_t var_log_t:file { create getattr open read write };

# Log-Dateien schreiben in /home/httpd/*/logs/
allow httpd_t httpd_log_t:file { unlink write };

# xfs_quota: block device access + filesystem quota modification
allow httpd_t fixed_disk_device_t:blk_file { getattr ioctl open read };
allow httpd_t fs_t:filesystem { quotaget quotamod };

# useradd creating mail home dirs in /home/pop/ (user_home_dir_t = parent dir)
allow httpd_t user_home_dir_t:dir { add_name create getattr read remove_name search setattr write };
allow httpd_t user_home_dir_t:file { create getattr open read write };

# useradd creating subdirs inside /home/pop/mailX.domain/ (user_home_t = child)
allow httpd_t user_home_t:dir { add_name create getattr read remove_name search setattr write };
allow httpd_t user_home_t:file { create getattr open read unlink write };

# cp creating GoAccess cron job in /etc/cron.daily/ (bin_t)
allow httpd_t bin_t:dir { add_name getattr read remove_name search write };
allow httpd_t bin_t:file { create entrypoint getattr open read setattr unlink write };

# certbot: /var/lib/letsencrypt/ lock file + work dir (cert_t)
allow httpd_t cert_t:dir { add_name create getattr read remove_name search write };
allow httpd_t cert_t:file { create getattr open read rename unlink write };

# useradd: mailbox file creation in /var/spool/mail/
allow httpd_t mail_spool_t:dir { add_name getattr search write };
allow httpd_t mail_spool_t:file { create getattr open read write };

# certbot: getattr on system config files (read-only system checks)
allow httpd_t adjtime_t:file getattr;
allow httpd_t cupsd_rw_etc_t:file getattr;
allow httpd_t etc_aliases_t:file getattr;
allow httpd_t exports_t:file getattr;
allow httpd_t initrc_exec_t:file getattr;
allow httpd_t kdump_etc_t:file getattr;
allow httpd_t rsync_etc_t:file getattr;
allow httpd_t syslog_conf_t:file getattr;
allow httpd_t system_cron_spool_t:file getattr;

# Apache service status for reload (systemd)
allow httpd_t httpd_unit_file_t:service status;

# ---- logrotate_t ----

# logrotate reading httpd_sys_content_t directories
allow logrotate_t httpd_sys_content_t:dir read;
