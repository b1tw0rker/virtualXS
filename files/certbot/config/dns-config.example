#!/bin/bash
### Certbot DNS Challenge Konfiguration
### Version 1.0.0
### last-modified: 08.05.2026
###

### DNS Provider Settings
###
DNS_SERVER="dns.example.invalid"
DNS_PORT="8081"
API_KEY="replace-with-your-api-key"

### Let's Encrypt Settings
###
EMAIL="admin@example.com"
STAGING_MODE="false"
AGREE_TOS="--agree-tos"

### Logging Settings
###
LOG_FILE="/var/log/certbot-dns/certbot-dns.log"

### DNS Settings
###
DNS_PROPAGATION_WAIT=60
TTL=60

### Hook Settings
###
#WEBMIN_RESTART="true"
NOTIFICATION_ENABLED="false"