#!/bin/bash

printf "\n********************************************************************\n\n%d) Disable kernel modules (printer, USB storage, Bluetooth, unused protocols) [y/N]: " "$(( ++_vxs_step ))"
if [ "$u_module_blacklist" = "" ]; then
    read u_module_blacklist
fi

if [ "$u_module_blacklist" = "y" ]; then
    printf "\n"
    folder_modprobe=/etc/modprobe.d

    if [ ! -d "$folder_modprobe" ]; then
        mkdir -p "$folder_modprobe"
    fi

    if ! cp $u_path/files/firewall/99-bw-module-blacklist.conf $folder_modprobe; then
        printf "[\e[31mERROR\e[0m] cp 99-bw-module-blacklist.conf failed\n"
    else
        printf "[\e[32mOK\e[0m] kernel module blacklist applied\n"
    fi

fi
