#!/bin/bash

### Sources
### color formating: https://misc.flogisoft.com/bash/tip_colors_and_formatting
###
###

### Global step counter for question numbering
###
_vxs_step=0

### Log output helper
### Prints a colored status line: ok (green), error (red), info (cyan), warn (yellow).
### Usage: _log ok|error|info|warn "message"
### version 1.0.0
### last-modified: 16.05.26
###
_log() {
    local level="${1^^}"
    shift
    local msg="$*"
    case "$level" in
        OK)    printf "[\e[32mOK\e[0m]    %s\n" "$msg" ;;
        ERROR) printf "[\e[31mERROR\e[0m] %s\n" "$msg" ;;
        INFO)  printf "[\e[36mINFO\e[0m]  %s\n" "$msg" ;;
        WARN)  printf "[\e[33mWARN\e[0m]  %s\n" "$msg" ;;
        *)     printf "[%s] %s\n" "$level" "$msg" ;;
    esac
}

### Confirm function
### version 1.0.0
### last-modified: 01.10.23
###
confirm() {
    local prompt="$1"
    local preset="$2"                # raw value – may be empty in manual mode
    local default_value="${preset:-N}"
    local result

    # Auto-accept only if explicitly pre-set to y/n (empty = ask interactively)
    case ${preset,,} in
        "y" | "yes") printf "%s [y/N]: y\n" "$prompt"; return 0 ;;
        "n" | "no")  printf "%s [y/N]: n\n" "$prompt"; return 1 ;;
    esac

    while true; do
        read -p "$prompt [y/N]: " -i "$default_value" result
        case ${result,,} in          # Konvertiert die Eingabe in Kleinbuchstaben, um Groß- und Kleinschreibung zu ignorieren
        "y" | "yes") return 0 ;;     # return 0 bedeutet Erfolg bzw. "ja"
        "n" | "no" | "") return 1 ;; # return 1 bedeutet "nein"; das leere "" fängt eine Enter-Eingabe ohne Inhalt ab
        *) echo "Please enter only 'y' or 'n'." ;;
        esac
    done
}

### Abort VirtualXS on Ctrl+C
###
### Beendet den laufenden Installer sauber nach SIGINT.
### Exit-Code 130 entspricht einem durch den Benutzer abgebrochenen Prozess.
### version 1.0.0
### last-modified: 12.05.26
###
abort_vxs() {
    printf "\nAborted by user.\n"
    exit 130
}

### SELinux: Sicherstellen, dass policycoreutils und semanage vorhanden sind.
### Gibt 1 zurueck wenn Tools nicht installiert werden konnten.
### version 1.0.0
### last-modified: 16.05.26
###
_selinux_ensure_tools() {
    if ! command -v setsebool &>/dev/null || ! command -v restorecon &>/dev/null || ! command -v setenforce &>/dev/null; then
        _log info "policycoreutils fehlt – wird nachinstalliert"
        if ! dnf -y install policycoreutils 2>/dev/null; then
            _log error "policycoreutils konnte nicht installiert werden"
            return 1
        fi
        _log ok "policycoreutils installiert"
    fi
    if ! command -v semanage &>/dev/null; then
        _log info "semanage fehlt – installiere policycoreutils-python-utils"
        if ! dnf -y install policycoreutils-python-utils 2>/dev/null; then
            _log error "policycoreutils-python-utils konnte nicht installiert werden"
            return 1
        fi
        _log ok "policycoreutils-python-utils installiert"
    fi
}

### SELinux: Einen Boolean persistent setzen.
### Prueft Verfuegbarkeit via getsebool; setzt mit setsebool -P.
### Usage: _selinux_set_bool <boolean> [on|off]
### version 1.0.0
### last-modified: 16.05.26
###
_selinux_set_bool() {
    local bool="$1" val="${2:-on}"
    if ! getsebool "$bool" &>/dev/null; then
        _log info "SELinux Boolean $bool – auf diesem System nicht verfuegbar"
        return
    fi
    if setsebool -P "$bool" "$val" 2>/dev/null; then
        _log ok "setsebool -P $bool $val"
    else
        _log error "setsebool -P $bool $val – fehlgeschlagen"
    fi
}

### SELinux: restorecon fuer einen Pfad ausfuehren (nur wenn Pfad existiert).
### Usage: _selinux_restorecon <path>
### version 1.0.0
### last-modified: 16.05.26
###
_selinux_restorecon() {
    local path="$1"
    if [ ! -e "$path" ]; then
        _log info "restorecon: $path nicht vorhanden – uebersprungen"
        return
    fi
    if restorecon -Rv "$path" >/dev/null 2>&1; then
        _log ok "restorecon -Rv $path"
    else
        _log error "restorecon -Rv $path – fehlgeschlagen"
    fi
}

### print centered some lines and write some infos
### https://superuser.com/questions/823883/how-to-justify-and-center-text-in-bash/829870
### version 1.0.0
### last-modified: 01.10.23
###
print_center() {
    local x
    local y
    text="$*"
    x=$((($(tput cols) - ${#text}) / 2))
    echo -ne "\E[6n"
    read -sdR y
    y=$(echo -ne "${y#*[}" | cut -d';' -f1)
    echo -ne "\033[${y};${x}f$*"
}
