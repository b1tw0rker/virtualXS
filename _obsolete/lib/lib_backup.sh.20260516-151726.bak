#!/bin/bash

printf "\n********************************************************************\n\nGIT Clone RSYNC backup script to: /etc/bitworker [y/N]: "
if [ "$u_backup" = "" ]; then
    read u_backup
fi

if [ "$u_backup" = "y" ]; then

    if ! git clone https://github.com/b1tw0rker/rsync.git /etc/bitworker/rsync/; then
        printf "[\e[31mERROR\e[0m] git clone failed\n"
    else
        chmod 700 /etc/bitworker/rsync/copyjob.sh

        sed -i 's/^target="XXX"/host="srv011.bit-worker.com"/' /etc/bitworker/rsync/copyjob.sh
        sed -i 's/^active="false"/active="true"/' /etc/bitworker/rsync/copyjob.sh

        ### create cronjob in cron.daily
        ###
        ###
        if ! cp $u_path/files/backup/copyjobcron /etc/cron.daily/copyjob; then
            printf "[\e[31mERROR\e[0m] cp copyjobcron failed\n"
        else
            chmod 700 /etc/cron.daily/copyjob
            printf "[\e[32mOK\e[0m] backup cronjob installed\n"
        fi
    fi

fi
