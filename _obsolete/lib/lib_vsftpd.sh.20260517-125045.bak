#!/bin/bash

### /etc/vsftpd/
###
###
printf "\n********************************************************************\n\n%d) Configure Vsftpd [y/N]: " "$(( ++_vxs_step ))"
if [ "$u_vsftpd" = "" ]; then
    read u_vsftpd
fi



if [ "$u_vsftpd" = "y" ]; then
    printf "\n"
    file_vsftpd001=/etc/vsftpd/vsftpd_user_conf
    file_vsftpd002=/etc/vsftpd/vsftpd.conf
    file_vsftpd003=/etc/pam.d/vsftpd
    file_vsftpd004=/etc/letsencrypt/live/$u_srv/fullchain.pem
    file_vsftpd007=/etc/bitworker/bw-vsftpd-pam-userlogin-check.sh

    if [ ! -f "$file_vsftpd007" ]; then
        _log error "Missing helper script: $file_vsftpd007"
        _log warn "Run helper-apps first so files/bitworker is copied to /etc/bitworker"
        return 1
    fi

    useradd -d /dev/null -s /sbin/nologin -g users vsftpd >>/dev/null 2>&1

    ### /sbin/nologin must be in /etc/shells for vsftpd's internal shell check
    ###
    ###
    grep -qxF '/sbin/nologin'     /etc/shells || echo '/sbin/nologin'     >> /etc/shells
    grep -qxF '/usr/sbin/nologin' /etc/shells || echo '/usr/sbin/nologin' >> /etc/shells

    if [ ! -d "$file_vsftpd001" ]; then
        mkdir "$file_vsftpd001"
    fi

    # One-time backup of the original vsftpd.conf
    if [ -f "$file_vsftpd002" ] && [ ! -f /etc/vsftpd/vsftpd.orig ]; then
        cp "$file_vsftpd002" /etc/vsftpd/vsftpd.orig
        _log ok "Original gesichert: /etc/vsftpd/vsftpd.orig"
    fi

    cat "$u_path/files/vsftpd/vsftpd.conf" >>"$file_vsftpd002"

    ### MySQL credentials for PAM auth script
    ### /etc/vsftpd/.my.cnf is written by vxs during MySQL setup (vsftpd user, not root).
    ### Only fall back to /root/.my.cnf if the vsftpd-specific file is missing.
    if [ -f /etc/vsftpd/.my.cnf ]; then
        _log ok "MySQL-Zugangsdaten vorhanden: /etc/vsftpd/.my.cnf"
    elif [ -f /root/.my.cnf ]; then
        cp /root/.my.cnf /etc/vsftpd/.my.cnf
        chmod 600 /etc/vsftpd/.my.cnf
        chown root:root /etc/vsftpd/.my.cnf
        _log warn "Fallback: /root/.my.cnf nach /etc/vsftpd/.my.cnf kopiert (vsftpd-User noch nicht angelegt)"
    else
        _log error "/root/.my.cnf nicht gefunden – /etc/vsftpd/.my.cnf fehlt"
    fi

    ### pam_exec script + PAM config
    ###
    ###
    if [ -f "$file_vsftpd003" ]; then
        cat "$u_path/files/vsftpd/pam_vsftpd" >"$file_vsftpd003"
    fi

    ### Cert stuff
    ###
    ###
    if [ -f "$file_vsftpd004" ]; then
        sed -i \
            -e "s|^#\?rsa_cert_file=.*|rsa_cert_file=/etc/letsencrypt/live/${u_srv}/fullchain.pem|" \
            -e "s|^#\?rsa_private_key_file=.*|rsa_private_key_file=/etc/letsencrypt/live/${u_srv}/privkey.pem|" \
            "$file_vsftpd002"
        _log ok "SSL cert aktiviert: /etc/letsencrypt/live/${u_srv}/"
    else
        _log warn "SSL cert nicht gefunden – rsa_cert_file bleibt auskommentiert"
    fi

    ### Start or restart vsftpd
    ###
    ###
    if systemctl is-active --quiet vsftpd; then
        if systemctl restart vsftpd; then
            _log ok "Vsftpd restarted"
        else
            _log error "Vsftpd restart failed – check: journalctl -xeu vsftpd.service"
        fi
    else
        if systemctl enable --now vsftpd; then
            _log ok "Vsftpd gestartet"
        else
            _log error "Vsftpd start failed – check: journalctl -xeu vsftpd.service"
        fi
    fi

    ### --- SELinux: VSFTPD Booleans + Dateikontexte -------------
    ###   ftpd_connect_db       – vsftpd verbindet sich mit Datenbank (PAM/MySQL)
    ###   ftpd_use_passive_mode – passiver FTP-Modus erlaubt
    ###
    printf "\n--- SELinux: VSFTPD ---\n"
    _selinux_ensure_tools
    _selinux_set_bool ftpd_connect_db
    _selinux_set_bool ftpd_use_passive_mode
    _selinux_restorecon /home/pop

fi
