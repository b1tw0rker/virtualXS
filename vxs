if vxs_should_run_from virtualx; then

    ###
    ### *** VIRTUALX ***
    ###
    printf "\n********************************************************************\n"
    printf "*                         V I R T U A L X                          *\n"
    printf "********************************************************************\n\n"

    ### q virtualx mysql schema
    ###
    ###
    if ! systemctl is-active --quiet mysqld; then
        printf "[\e[33mWARN\e[0m] MySQL läuft nicht – Schema-Abschnitt übersprungen\n"
    else
        # Detect existing virtualx database
        _vx_db_exists=$(mysql -u root -e "SHOW DATABASES LIKE 'virtualx';" 2>/dev/null | grep -c "virtualx" || true)

        if [ "$_vx_db_exists" -gt 0 ]; then
            printf "[\e[36mINFO\e[0m] virtualX-Datenbank ist bereits vorhanden.\n"
            printf "  [1] Schema-Update durchführen  (neue Tabellen anlegen, vorhandene behalten)\n"
            printf "  [2] Datenbank löschen und neu installieren  (DROP DATABASE virtualx)\n"
            printf "  [3] Überspringen\n"
            printf "Wähle eine Option (1-3) [3]: "
            if [ "$u_virtualx_schema" = "" ]; then
                read u_virtualx_schema
            fi
            case "$u_virtualx_schema" in
                1)
                    mysql -u root <"$u_path/files/virtualx/virtualx-mysql-schema.sql"
                    printf "[\e[32mOK\e[0m] virtualX Schema-Update abgeschlossen\n"
                    ;;
                2)
                    printf "[\e[33mWARN\e[0m] Datenbank 'virtualx' wird gelöscht...\n"
                    mysql -u root -e "DROP DATABASE virtualx;"
                    mysql -u root <"$u_path/files/virtualx/virtualx-mysql-schema.sql"
                    printf "[\e[32mOK\e[0m] virtualX Datenbank neu installiert\n"
                    ;;
                *)
                    printf "[\e[32mOK\e[0m] Schema-Installation übersprungen\n"
                    ;;
            esac
        else
            printf "%d) Install virtualX MySQL schema [y/N]: " "$(( ++_vxs_step ))"
            if [ "$u_virtualx_schema" = "" ]; then
                read u_virtualx_schema
            fi
            if [ "$u_virtualx_schema" = "y" ]; then
                mysql -u root <"$u_path/files/virtualx/virtualx-mysql-schema.sql"
                printf "[\e[32mOK\e[0m] virtualX MySQL schema installed\n"
            fi
        fi
    fi

    ### q virtualx first vhost
    ###
    ###
    source $u_path/lib/lib_virtualx.sh

fi

