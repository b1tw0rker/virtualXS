        INTERFACE=$(cat $dir001/interface)
        read -p "4/6 • NetworkInterface: " -ei $INTERFACE u_iface
    else
        read -p "4/6 • NetworkInterface: " -ei $u_iface u_iface
        printf "$u_iface" >$dir001/interface
    fi

    ### Ask for MySql Password
    ###
    ###
    _mycnf_exists=false
    [ -f /root/.my.cnf ] && _mycnf_exists=true

    while true; do
        # Erste Abfrage
        if $_mycnf_exists; then
            read -s -p "5/6 • Set MySQL root password (Enter = keep current): " u_mysql_pwd
        else
            read -s -p "5/6 • Set MySQL root password: " u_mysql_pwd
        fi
        echo # Zeilenumbruch nach der Eingabe, da -s keinen Zeilenumbruch erzeugt

        # Leeres Passwort: nur erlaubt wenn .my.cnf bereits existiert (=> unveraendert lassen)
        if [ -z "$u_mysql_pwd" ]; then
            if $_mycnf_exists; then
                read -s -p "6/6 • Confirm (Enter = keep current): " u_mysql_pwd_confirm
                echo
                if [ -z "$u_mysql_pwd_confirm" ]; then
                    _log info "MySQL password unchanged."
                    unset u_mysql_pwd u_mysql_pwd_confirm _mycnf_exists
                    break
                else
                    _log warn "Confirmation was not empty. Please try again."
                    continue
                fi
            else
                _log warn "Password must not be empty. Please enter a password."
                continue
            fi
        fi

        # Second prompt for confirmation
        read -s -p "6/6 • Confirm MySQL root password: " u_mysql_pwd_confirm
        echo # Zeilenumbruch

        # Vergleiche die beiden Eingaben
        if [ "$u_mysql_pwd" == "$u_mysql_pwd_confirm" ]; then
            _log ok "Passwords match"
            printf '[client]\npassword=%s\n' "$u_mysql_pwd" > /root/.my.cnf
            chmod 600 /root/.my.cnf
            mkdir -p /etc/vsftpd
            printf '[client]\npassword=%s\n' "$u_mysql_pwd" > /etc/vsftpd/.my.cnf
            chmod 600 /etc/vsftpd/.my.cnf
            chown root:root /etc/vsftpd/.my.cnf

            _log info "Starting MySQL"
            systemctl start mysqld >/dev/null 2>&1

            _log ok "MySQL Server started"

            if mysqladmin -u root password "$u_mysql_pwd" >/dev/null 2>&1; then
                _log ok "Changed MySQL root password successfully"
            else
                _log error "Could not change MySQL root password"
            fi



            unset u_mysql_pwd u_mysql_pwd_confirm _mycnf_exists
            break # Schleife verlassen

        else
            _log warn "Passwords do not match. Please try again."
        fi
    done

    ###
    ###
    ###
    printf "\n********************************************************************\n\n"
    printf "  w = Web Server  (automated, all steps preset)\n"
    printf "  d = DNS Server  (automated, all steps preset)\n"
    printf "  m = Manual      (web server steps, each question asked individually)\n\n"
